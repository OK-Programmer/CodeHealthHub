<button type="button"
    class="btn p-0 m-0 bi bi-info-circle-fill"
    data-bs-toggle="tooltip" 
    data-bs-placement="bottom" 
    data-bs-trigger="focus"
    title="@TooltipText">
    @* <i class="bi bi-info-circle-fill"></i> *@
</button>

@code {
    [Parameter]
    public string TooltipText { get; set; } = "Tooltip info text";
}
