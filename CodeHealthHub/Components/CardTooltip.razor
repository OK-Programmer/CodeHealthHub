<div class="float-end">
    <button type="button"
        class="btn btn-sm p-0 m-0 bi bi-info-circle-fill"
        data-bs-toggle="tooltip" 
        data-bs-placement="bottom" 
        data-bs-trigger="focus"
        title="@TooltipText">
    </button>
</div>

@code {
    [Parameter]
    public string TooltipText { get; set; } = "Tooltip info text";
}
