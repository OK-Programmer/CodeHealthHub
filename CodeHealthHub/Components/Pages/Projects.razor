@page "/projects"
@using CodeHealthHub.Models
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject NavigationManager navigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Projects Management</PageTitle>

<h1>Manage Projects</h1>

<p>This is the projects management page. Here you can edit or remove projects.</p>

<div class="row d-flex justify-content-center">
    <div class="col-8 text-end">
        @if (isEditing)
        {
            <button class="btn btn-success me-2" @onclick="() => SaveEdit()">Save</button>
            <button class="btn btn-secondary me-2" @onclick="CancelEdit">Cancel</button>
        }
        else
        {
            <button class="btn btn-secondary me-2" @onclick="EnterEditMode">Edit</button>
        }
        <button type="button" class="btn btn-outline-dark me-2" @onclick="RefreshProjects">Refresh Project Data</button>
    </div>
</div>

<div class="row d-flex justify-content-center">
    <div class="col-8 justify-content-center">
        <table class="table w-100">
            <thead>
                <tr>
                    <th>Project ID</th>
                    <th>Name</th>
                    <th>Key</th>
                    <th>Developer Count</th>
                    <th>Developer Cost/hr</th>
                    <th>Weight</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @for(int i = 0; i < projects.Count; i++)
                {
                var rowIndex = i;
                var project = projects[rowIndex];
                var tempWeight = project.Weight.ToString("0.00");
                var tempNumOfDevs = project.NumOfDevelopers.ToString();
                var tempDevCost = project.DeveloperCostPerHour.ToString();
                <tr>
                    <td>@project.Id</td>
                    <td>@project.Name</td>
                    <td>@project.Key</td>
                    <td>
                        @if (!isEditing) { @tempNumOfDevs }
                        else { 
                            <InputText 
                            @bind-Value="tempNumOfDevs"
                            class="form-control form-control-sm" 
                            @oninput="e => { if (int.TryParse(e.Value?.ToString(), out int result)) { project.NumOfDevelopers = result; } }"/> 
                        }
                    </td>
                    <td>
                        @if (!isEditing) { @tempDevCost }
                        else { 
                            <InputText 
                            @bind-Value="tempDevCost"
                            class="form-control form-control-sm" 
                            @oninput="e => { if (double.TryParse(e.Value?.ToString(), out double result)) { project.DeveloperCostPerHour = result; } }"/> 
                        }
                    </td>
                    <td>
                        @if (!isEditing) { @tempWeight }
                        else { 
                            <InputText 
                            @bind-Value="tempWeight"
                            class="form-control form-control-sm" 
                            @oninput="e => {if (double.TryParse(e.Value?.ToString(), out double result)) { project.Weight = result; } }"/> 
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-danger">Delete</button>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>


@code
{
    List<SonarQubeProject> projects = new List<SonarQubeProject>();
    @* List<string> weights = new List<string>(); *@
    List<SonarQubeProject> originalProjects = new List<SonarQubeProject>();
    @* List<string> originalWeights = new List<string>(); *@

    bool isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        string allProjectsURL = "api/projects/all";
        HttpClient client = HttpFactory.CreateClient("LocalApi");
        projects = await client.GetFromJsonAsync<List<SonarQubeProject>>(allProjectsURL) ?? new List<SonarQubeProject>();
        @* foreach (SonarQubeProject project in projects)
        {
            weights.Add(String.Format("{0:0.000}", project.Weight));
        } *@
    }

    // When entering edit mode, backup the original data
    void EnterEditMode()
    {
        // Deep copy projects (shallow copy is not enough if you edit properties)
        originalProjects = projects.Select(p => new SonarQubeProject
        {
            Id = p.Id,
            Name = p.Name,
            Key = p.Key,
            LastAnalysisDate = p.LastAnalysisDate,
            NumOfDevelopers = p.NumOfDevelopers,
            DeveloperCostPerHour = p.DeveloperCostPerHour,
            Weight = p.Weight
        }).ToList();

        isEditing = true;
    }

    // When cancelling, restore the original data
    void CancelEdit()
    {
        // Restore values
        projects = originalProjects.Select(p => new SonarQubeProject
        {
            Id = p.Id,
            Name = p.Name,
            Key = p.Key,
            LastAnalysisDate = p.LastAnalysisDate,
            NumOfDevelopers = p.NumOfDevelopers,
            DeveloperCostPerHour = p.DeveloperCostPerHour,
            Weight = p.Weight
        }).ToList();

        isEditing = false;
    }

    protected async Task<bool> ValidateWeights()
    {
        double totalWeight = 0.0;
        // Input Vdalidation for all project weights
        for(int i = 0; i < projects.Count; i++)
        {
            if (projects[i].Weight.GetType() != typeof(double))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Weight must be a decimal number");
                return false;
            }

            if (projects[i].Weight.GetType() == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Weight cannot be empty");
                return false;
            }

            totalWeight += projects[i].Weight;
        }

        if (totalWeight != 1.0)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Total weight must be equal to 1.0");
            return false;
        }

        return true;
    }

    protected async Task<bool> ValidateDeveloperVariables()
    {
        // Input Validation for Developer Count and Cost
        for(int i = 0; i < projects.Count; i++)
        {
            if (projects[i].NumOfDevelopers.GetType() != typeof(int))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Number of Developers must be a whole number");
                return false;
            }

            if (projects[i].NumOfDevelopers < 0)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Number of Developers cannot be negative");
                return false;
            }

            if (projects[i].DeveloperCostPerHour.GetType() != typeof(double))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Developer Cost per Hour must be a decimal number");
                return false;
            }

            if (projects[i].DeveloperCostPerHour < 0.0 || projects[i].DeveloperCostPerHour > 1000.0)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Developer Cost per Hour is invalid");
                return false;
            }
        }

        return true;
    }

    protected async Task SaveEdit()
    {
        isEditing = false;

        if(await ValidateWeights() == false || await ValidateDeveloperVariables() == false)
        {
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
        else
        {
            await SaveWeights();
            await SaveNumberOfDevs();
            await SaveDeveloperCost();
        }        
    }

    protected async Task SaveWeights()
    {
        // Prepare updated weights dictionary
        Dictionary<int, double> updatedWeights = new Dictionary<int, double>();
        for(int i = 0; i < projects.Count; i++)
        {
            updatedWeights[projects[i].Id] = projects[i].Weight;
        }

        // Call API to save updated weights
        string saveEditsURL = $"api/projects/update-weights";
        HttpClient client = HttpFactory.CreateClient("LocalApi");
        HttpResponseMessage? response = await client.PutAsJsonAsync(saveEditsURL, updatedWeights); // Id-1 to convert to 0-based index

        if (response.IsSuccessStatusCode)
        {
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
        else
        {
            Debug.WriteLine("Error saving edits: " + response.ReasonPhrase);
            await JSRuntime.InvokeVoidAsync("alert", "Error saving edits: " + response.ReasonPhrase);
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
    }

    protected async Task SaveNumberOfDevs()
    {
        // Prepare updated dev count dictionary
        Dictionary<int, int> updatedDevCount = new Dictionary<int, int>();
        for(int i = 0; i < projects.Count; i++)
        {
            updatedDevCount[projects[i].Id] = projects[i].NumOfDevelopers;
        }

        // Call API to save updated developer variables
        string saveDevsURL = $"api/projects/update-developer-count";
        HttpClient client = HttpFactory.CreateClient("LocalApi");
        HttpResponseMessage? response = await client.PutAsJsonAsync(saveDevsURL, updatedDevCount);

        if (response.IsSuccessStatusCode)
        {
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
        else
        {
            Debug.WriteLine("Error saving number of devs: " + response.ReasonPhrase);
            await JSRuntime.InvokeVoidAsync("alert", "Error saving number of devs: " + response.ReasonPhrase);
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
    }

    protected async Task SaveDeveloperCost()
    {
        // Prepare updated dev cost dictionary
        Dictionary<int, double> updatedDevCost = new Dictionary<int, double>();
        for(int i = 0; i < projects.Count; i++)
        {
            updatedDevCost[projects[i].Id] = projects[i].DeveloperCostPerHour;
        }

        // Call API to save updated developer variables
        string saveCostURL = $"api/projects/update-developer-cost";
        HttpClient client = HttpFactory.CreateClient("LocalApi");
        HttpResponseMessage? response = await client.PutAsJsonAsync(saveCostURL, updatedDevCost);

        if (response.IsSuccessStatusCode)
        {
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
        else
        {
            Debug.WriteLine("Error saving developer cost: " + response.ReasonPhrase);
            await JSRuntime.InvokeVoidAsync("alert", "Error saving developer cost: " + response.ReasonPhrase);
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
    }

    protected async Task RefreshProjects()
    {
        try
        {
            string requestUri = "api/projects/refresh";
            HttpClient httpClient = HttpFactory.CreateClient("LocalApi");
            Debug.WriteLine($"Calling URL: {httpClient.BaseAddress}{requestUri}");
            HttpResponseMessage response = await httpClient.GetAsync(requestUri);
            if (response.IsSuccessStatusCode)
            {
                navigationManager.NavigateTo(navigationManager.Uri, true);
            }
            else
            {
                Debug.WriteLine("Error refreshing projects data: " + response.ReasonPhrase);
            }
        }
        catch (Exception e)
        {
            Debug.WriteLine("Exception when calling RefreshProjects(): " + e);
            navigationManager.NavigateTo("/Error");
        }
    }
}