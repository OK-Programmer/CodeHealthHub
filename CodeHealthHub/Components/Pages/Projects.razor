@page "/projects"
@using CodeHealthHub.Models
@inject IHttpClientFactory HttpFactory
@inject NavigationManager navigationManager

<PageTitle>Projects Management</PageTitle>

<h1>Manage Projects</h1>

<p>This is the projects management page. Here you can edit or remove projects.</p>

<div class="row d-flex justify-content-center">
    <div class="col-8">
        <table class="table w-100">
            <thead>
                <tr>
                    <th>Project ID</th>
                    <th>Name</th>
                    <th>Key</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var project in projects)
                {
                <tr>
                    <td>@project.Id</td>
                    <td>@project.Name</td>
                    <td>@project.Key</td>
                    <td>
                    <button class="btn btn-sm btn-secondary">Edit</button>
                    <button class="btn btn-sm btn-danger">Delete</button>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="row d-flex justify-content-center">
    <div class="col-8 text-end">
        <button class="btn btn-sm btn-primary">Add</button> 
    </div>
</div>


@code
{
    List<SonarQubeProject> projects = new List<SonarQubeProject>();

    protected override async Task OnInitializedAsync()
    {
        var allProjectsURL = "api/projects/all";
        var client = HttpFactory.CreateClient("LocalApi");
        projects = await client.GetFromJsonAsync<List<SonarQubeProject>>(allProjectsURL) ?? new List<SonarQubeProject>();
    }
}