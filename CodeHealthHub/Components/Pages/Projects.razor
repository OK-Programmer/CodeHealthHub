@page "/projects"
@using CodeHealthHub.Models
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject NavigationManager navigationManager
@inject IJSRuntime JSRuntime


<PageTitle>Projects Management</PageTitle>

<div class="mb-4">
    <h1>Manage Projects</h1>
    <p>This is the projects management page. Here you can refresh, edit or remove projects.</p>
    <hr />
</div>

<div class="row d-flex justify-content-center">
    <div class="col-10">
        <div class="card">
            <div class="card-body p-6">
                <div class="col text-end mb-3">
                    @if (isEditing)
                    {
                        <button class="btn btn-success me-2" @onclick="() => SaveEdit()">Save</button>
                        <button class="btn btn-danger me-2" @onclick="CancelEdit">Cancel</button>
                    }
                    else if (projects.Any())
                    {
                        <button class="btn btn-secondary me-2" @onclick="EnterEditMode">Edit</button>
                    }
                    else
                    {
                        <button class="btn btn-secondary me-2" @onclick="EnterEditMode" disabled>Edit</button>
                    }
                    <button type="button" class="btn btn-outline-dark me-2" @onclick="RefreshProjects">Refresh Project Data</button>
                </div>

                @if (projects.Any())
                {
                    <table class="table w-100">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Key</th>
                                <th>Developer Count</th>
                                <th>Developer Cost/hr</th>
                                <th>Weight</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for(int i = 0; i < projects.Count; i++)
                            {
                                var project = projects[i];
                                <tr>
                                    <td>@project.Name</td>
                                    <td>@project.Key</td>
                                    <td class="text-center">
                                        @if (!isEditing) { @project.NumOfDevelopers }
                                        else {
                                            <InputNumber
                                                @bind-Value="project.NumOfDevelopers"
                                                class="form-control form-control-sm" />
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!isEditing) { @project.DeveloperCostPerHour }
                                        else {
                                            <InputNumber
                                                @bind-Value="project.DeveloperCostPerHour"
                                                class="form-control form-control-sm" />
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!isEditing) { @project.Weight.ToString("0.00") }
                                        else {
                                            <InputNumber
                                                @bind-Value="project.Weight"
                                                class="form-control form-control-sm" />
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteProject(project.Id)">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (isRefreshing)
                {
                    <div class="d-flex justify-content-center align-items-center" style="height: 200px;">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else 
                {
                    <div class="d-flex justify-content-center align-items-center" style="height: 200px;">
                        <strong>No project data found.</strong>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


@code
{
    public required HttpClient _httpClient;
    List<SonarQubeProject> projects { get; set; } = new List<SonarQubeProject>();
    List<SonarQubeProject> originalProjects { get; set; } = new List<SonarQubeProject>();
    bool isEditing = false;
    bool isRefreshing;

    protected override void OnInitialized()
    {
        _httpClient = HttpFactory.CreateClient("LocalApi");
        isRefreshing = false;
    }

    protected override async Task OnInitializedAsync()
    {
        string allProjectsURL = "api/projects/all";
        var loadedProjects = await _httpClient.GetFromJsonAsync<List<SonarQubeProject>>(allProjectsURL) ?? new List<SonarQubeProject>();
        projects.Clear();
        projects.AddRange(loadedProjects);
    }

    // When entering edit mode, backup the original data
    void EnterEditMode()
    {
        originalProjects.Clear();
        foreach (var p in projects)
        {
            originalProjects.Add(new SonarQubeProject
            {
                Id = p.Id,
                Name = p.Name,
                Key = p.Key,
                LastAnalysisDate = p.LastAnalysisDate,
                SonarQubeInstanceId = p.SonarQubeInstanceId,
                NumOfDevelopers = p.NumOfDevelopers,
                DeveloperCostPerHour = p.DeveloperCostPerHour,
                Weight = p.Weight
            });
        }
        isEditing = true;
    }

    // When cancelling, restore the original data
    void CancelEdit()
    {
        foreach (var orig in originalProjects)
        {
            var proj = projects.FirstOrDefault(p => p.Id == orig.Id);
            if (proj != null)
            {
                proj.Name = orig.Name;
                proj.Key = orig.Key;
                proj.LastAnalysisDate = orig.LastAnalysisDate;
                proj.SonarQubeInstanceId = orig.SonarQubeInstanceId;
                proj.NumOfDevelopers = orig.NumOfDevelopers;
                proj.DeveloperCostPerHour = orig.DeveloperCostPerHour;
                proj.Weight = orig.Weight;
            }
        }
        isEditing = false;
    }

    protected async Task<bool> ValidateWeights()
    {
        double totalWeight = 0.0;
        // Input Vdalidation for all project weights
        for(int i = 0; i < projects.Count; i++)
        {
            if (projects[i].Weight.GetType() != typeof(double))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Weight must be a decimal number");
                return false;
            }

            if (projects[i].Weight.GetType() == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Weight cannot be empty");
                return false;
            }

            totalWeight += projects[i].Weight;
        }

        if (totalWeight != 1.0)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Total weight must be equal to 1.0");
            return false;
        }

        return true;
    }

    protected async Task<bool> ValidateDeveloperVariables()
    {
        // Input Validation for Developer Count and Cost
        for(int i = 0; i < projects.Count; i++)
        {
            if (projects[i].NumOfDevelopers.GetType() != typeof(int))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Number of Developers must be a whole number");
                return false;
            }

            if (projects[i].NumOfDevelopers < 0)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Number of Developers cannot be negative");
                return false;
            }

            if (projects[i].DeveloperCostPerHour.GetType() != typeof(double))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Developer Cost per Hour must be a decimal number");
                return false;
            }

            if (projects[i].DeveloperCostPerHour < 0.0 || projects[i].DeveloperCostPerHour > 1000.0)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Developer Cost per Hour is invalid");
                return false;
            }
        }

        return true;
    }

    protected async Task SaveEdit()
    {
        isEditing = false;

        if(await ValidateWeights() == false || await ValidateDeveloperVariables() == false)
        {
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
        else
        {
            await SaveWeights();
            await SaveNumberOfDevs();
            await SaveDeveloperCost();
        }        
    }

    protected async Task SaveWeights()
    {
        // Prepare updated weights dictionary
        Dictionary<int, double> updatedWeights = new Dictionary<int, double>();
        for(int i = 0; i < projects.Count; i++)
        {
            updatedWeights[projects[i].Id] = projects[i].Weight;
        }

        // Call API to save updated weights
        string saveEditsURL = $"api/projects/update-weights";
        HttpResponseMessage? response = await _httpClient.PutAsJsonAsync(saveEditsURL, updatedWeights); // Id-1 to convert to 0-based index

        if (response.IsSuccessStatusCode)
        {
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
        else
        {
            Debug.WriteLine("Error saving edits: " + response.ReasonPhrase);
            await JSRuntime.InvokeVoidAsync("alert", "Error saving edits: " + response.ReasonPhrase);
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
    }

    protected async Task SaveNumberOfDevs()
    {
        // Prepare updated dev count dictionary
        Dictionary<int, int> updatedDevCount = new Dictionary<int, int>();
        for(int i = 0; i < projects.Count; i++)
        {
            updatedDevCount[projects[i].Id] = projects[i].NumOfDevelopers;
        }

        // Call API to save updated developer variables
        string saveDevsURL = $"api/projects/update-developer-count";
        HttpResponseMessage? response = await _httpClient.PutAsJsonAsync(saveDevsURL, updatedDevCount);

        if (response.IsSuccessStatusCode)
        {
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
        else
        {
            Debug.WriteLine("Error saving number of devs: " + response.ReasonPhrase);
            await JSRuntime.InvokeVoidAsync("alert", "Error saving number of devs: " + response.ReasonPhrase);
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
    }

    protected async Task SaveDeveloperCost()
    {
        // Prepare updated dev cost dictionary
        Dictionary<int, double> updatedDevCost = new Dictionary<int, double>();
        for(int i = 0; i < projects.Count; i++)
        {
            updatedDevCost[projects[i].Id] = projects[i].DeveloperCostPerHour;
        }

        // Call API to save updated developer variables
        string saveCostURL = $"api/projects/update-developer-cost";
        HttpResponseMessage? response = await _httpClient.PutAsJsonAsync(saveCostURL, updatedDevCost);

        if (response.IsSuccessStatusCode)
        {
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
        else
        {
            Debug.WriteLine("Error saving developer cost: " + response.ReasonPhrase);
            await JSRuntime.InvokeVoidAsync("alert", "Error saving developer cost: " + response.ReasonPhrase);
            navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
            return;
        }
    }

    protected async Task RefreshProjects()
    {
        try
        {
            isRefreshing = true;
            string requestUri = "api/projects/refresh";
            Debug.WriteLine($"Calling URL: {_httpClient.BaseAddress}{requestUri}");
            HttpResponseMessage response = await _httpClient.GetAsync(requestUri);
            if (response.IsSuccessStatusCode)
            {
                string allProjectsURL = "api/projects/all";
                var loadedProjects = await _httpClient.GetFromJsonAsync<List<SonarQubeProject>>(allProjectsURL) ?? new List<SonarQubeProject>();
                projects.Clear();
                projects.AddRange(loadedProjects);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error updating projects: " + response.ReasonPhrase);
                Debug.WriteLine("Error refreshing projects data: " + response.ReasonPhrase);
            }
            isRefreshing = false;
        }
        catch (Exception e)
        {
            Debug.WriteLine("Exception when calling RefreshProjects(): " + e);
            navigationManager.NavigateTo("/Error");
        }
    }

    protected async Task DeleteProject(int Id)
    {
        try
        {
            string requestUri = $"api/projects/{Id}";
            Debug.WriteLine($"Calling URL: {_httpClient.BaseAddress}{requestUri}");
            HttpResponseMessage response = await _httpClient.DeleteAsync(requestUri);
            if (response.IsSuccessStatusCode)
            {
                var projectToRemove = projects.FirstOrDefault(i => i.Id == Id);
                if (projectToRemove != null)
                {
                    projects.Remove(projectToRemove);
                }
            }
            else
            {
                Debug.WriteLine("Error deleting project: " + response.ReasonPhrase);
            }
        }
        catch (Exception e)
        {
            Debug.WriteLine($"Exception when calling DeleteProject(): {e}");
            navigationManager.NavigateTo("/Error");
        }
    }
}