@page "/"
@using System.Net.Http.Json
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject NavigationManager navigationManager

<PageTitle>Dashboard</PageTitle>

@* <div class="header-container">
    <h1>Dashboard</h1>
    <hr />
</div> *@

<!-- Summary Cards -->
<div class="row mb-4">
    <div class="col">
        <div class="card">
            <HealthScoreCard latestProjMeasures=@latestScansPerProj weights=@projectWeights></HealthScoreCard>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <TechDebtCard latestProjMeasures=@latestScansPerProj projects=@projects></TechDebtCard>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <IssuesCard issuesCount=@issuesCount effortTotal=@effortTotal></IssuesCard>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <SecurityCard projects=@projects issues=@issues></SecurityCard>
        </div>
    </div>
</div>

<!-- Projects Table and Charts -->
<div class="row mb-4">
    <div class="col">
        <div class="card">
            <ProjectsTable projects=@projects OnProjectFilterChanged="@HandleProjectFilterChanged"></ProjectsTable>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col">
        <div class="card">
            <ProjectIssueCountBarChart projects=@filteredProjects Issues=@issues></ProjectIssueCountBarChart>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <IssuesPieChart Issues=@issues projects=@filteredProjects piechartColours=@piechartColours></IssuesPieChart>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col">
        <div class="card">
            <TechDebtLineChart projects=@filteredProjects></TechDebtLineChart>
        </div>
    </div>
</div>


@code {
    private List<SonarQubeProject>? projects = new List<SonarQubeProject>();
    private List<SonarQubeProject>? filteredProjects = new List<SonarQubeProject>();
    private List<PieChartColour> piechartColours = new List<PieChartColour>();
    private List<ProjectIssue> issues = new List<ProjectIssue>();
    private List<double> projectWeights = new List<double>();
    private List<ProjectScan> latestScansPerProj = new List<ProjectScan>();
    private int? issuesCount, effortTotal;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await GetProjects();
            await GetIssues();
            await GetMeasures();
            await GetPiechartColours();
        }
        catch (Exception e)
        {
            Debug.WriteLine(e);
            navigationManager.NavigateTo("/Error");
        }
    }

    protected async Task GetProjects() 
    {
        try 
        {
            var requestUri = "api/dashboard/projects";
            HttpClient httpClient = HttpFactory.CreateClient("LocalApi");
            projects = await httpClient.GetFromJsonAsync<List<SonarQubeProject>>(requestUri);
            if (projects != null)
            {
                projectWeights = (from project in projects select project.Weight).ToList();
                filteredProjects = projects;
            }
        }
        catch (Exception)
        {
            throw;
        }
    }

    protected async Task GetIssues()
    {
        try 
        {
            List<ProjectIssue>? issueSearchResponse;
            var requestUri = "api/dashboard/issues";
            HttpClient httpClient = HttpFactory.CreateClient("LocalApi");
            Debug.WriteLine($"Calling URL: {httpClient.BaseAddress}{requestUri}");
            issueSearchResponse = await httpClient.GetFromJsonAsync<List<ProjectIssue>>(requestUri);
            if (issueSearchResponse != null)
            {
                issuesCount = issueSearchResponse.Count;
                effortTotal = issueSearchResponse.Sum(i => i.Effort);
                issues = issueSearchResponse;
            }
        }
        catch (Exception)
        {
            throw;
        }
    }

    protected async Task GetMeasures()
    {
        string? requestUri = "api/dashboard/measures";
        HttpClient httpClient = HttpFactory.CreateClient("LocalApi");
        Debug.WriteLine($"Calling URL: {httpClient.BaseAddress}{requestUri}");
        try 
        {
            var response = await httpClient.GetAsync(requestUri);
            if (response.IsSuccessStatusCode)
            {
                List<ProjectScan>? measuresResponse = await response.Content.ReadFromJsonAsync<List<ProjectScan>>();
                if (measuresResponse != null)
                {
                    latestScansPerProj.AddRange(measuresResponse);
                }
            }
            else
            {
                Debug.WriteLine($"Error fetching measures: {response.ReasonPhrase}");
            }
        }
        catch (Exception)
        {
            throw;
        }
    }

    protected async Task GetPiechartColours()
    {
        try
        {
            // Load existing color settings from a database if applicable
            var getColoursURL = "api/dashboard/piechart-colours";
            var client = HttpFactory.CreateClient("LocalApi");
            List<PieChartColour>? response = await client.GetFromJsonAsync<List<PieChartColour>>(getColoursURL);
            if (response != null)
            {
                Debug.WriteLine("Dashboard: fetched piechart colours successfully");
                piechartColours = response;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching colour settings: {ex.Message}");
            @* navigationManager.NavigateTo("/Error"); *@
        }
    }

    protected void HandleProjectFilterChanged(List<SonarQubeProject> filteredProjects)
    {
        this.filteredProjects = filteredProjects;
    }
}