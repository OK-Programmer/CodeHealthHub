@page "/"
@using CodeHealthHub.Models
@using System.Net.Http.Json
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject NavigationManager navigationManager

<PageTitle>Home</PageTitle>

<h1>Dashboard</h1>

<div class="d-flex justify-content-end mb-4">
    @if(showProjectsTable)
    {
        <button type="button" class="btn btn-sm btn-outline-dark" @onclick="ToggleProjectsTable">Hide Projects</button>
    }
    else
    {
        <button type="button" class="btn btn-sm btn-outline-dark" @onclick="ToggleProjectsTable">Show Projects</button>
    }
    <button type="button" class="btn btn-sm btn-outline-dark ms-1" @onclick="RefreshProjects">Refresh Project Data</button>
</div>

@if (!showProjectsTable)
{
    <div class="row mb-4">
        <div class="col">
            <div class="card">
                <div class="card-body">
                    Projects table is hidden
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row mb-4">
        <div class="col">
            <div class="card">
                <div class="table-responsive p-3">
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">Project Name</th>
                                <th scope="col">Last Analysis Date</th>
                                <th scope="col">Weight</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (projects == null) 
                            {
                                <p>Loading...</p>
                            }
                            else if (!projects.Any())
                            {
                                <p>No project data found.</p>
                            }
                            else
                            {
                                @foreach(SonarQubeProject project in projects)
                                {
                                    <tr>
                                        <td scope="row">@project.Id</td>
                                        <td>@project.Name</td>
                                        <td>@FormatDate(project.LastAnalysisDate)</td>
                                        <td>@String.Format("{0:0.000}", project.Weight)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}


<div class="row mb-4">
    <div class="col">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Health Score</h4>
                <p class="card-text">Overall Health Score: @overallHealthScore</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Issues</h4>
                <p class="card-text">
                    Total Issue Count: @issuesCount <br />
                    Total Effort: @effortTotal mins
                </p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Tech Debt</h4>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Security</h4>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col">
        <div class="card">
            <TestBarChart></TestBarChart>
        </div>
    </div>
    <div class="col">
        <div class="card">
            <IssuesPieChart Issues=@issues></IssuesPieChart>
        </div>
    </div>
</div>

@code {
    private List<SonarQubeProject>? projects = new List<SonarQubeProject>();
    private IssueSearchResponse? issueSearchResponse = new IssueSearchResponse();
    private List<Issue>? issues = new List<Issue>();
    private int? issuesCount, effortTotal;
    private bool showProjectsTable = true; 
    private string? overallHealthScore;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await GetProjects();
            await GetIssues();
            await GetMeasures();
        }
        catch (Exception e)
        {
            Debug.WriteLine(e);
            navigationManager.NavigateTo("/Error");
        }
    }

    protected async Task GetProjects() 
    {
        try 
        {
            var requestUri = "api/dashboard/projects";
            HttpClient httpClient = HttpFactory.CreateClient("LocalApi");
            projects = await httpClient.GetFromJsonAsync<List<SonarQubeProject>>(requestUri);
            if (projects != null)
            {
                StateHasChanged();
                foreach(SonarQubeProject project in projects)
                {
                    Debug.WriteLine(project.Name);
                }
            }
        }
        catch (Exception)
        {
            throw;
        }
    }

    protected async Task GetIssues()
    {
        try 
        {
            var requestUri = "api/dashboard/issues";
            HttpClient httpClient = HttpFactory.CreateClient("LocalApi");
            Debug.WriteLine($"Calling URL: {httpClient.BaseAddress}{requestUri}");
            issueSearchResponse = await httpClient.GetFromJsonAsync<IssueSearchResponse>(requestUri);
            if (issueSearchResponse != null)
            {
                issuesCount = issueSearchResponse.total;
                effortTotal = issueSearchResponse.effortTotal;
                issues = issueSearchResponse.issues;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            throw;
        }
    }

    protected async Task GetMeasures()
    {
        List<ProjectHealthScore>? allProjectHealthScores = new List<ProjectHealthScore>();
        string? requestUri = "api/dashboard/measures";
        HttpClient httpClient = HttpFactory.CreateClient("LocalApi");
        Debug.WriteLine($"Calling URL: {httpClient.BaseAddress}{requestUri}");
        try 
        {
            List<List<Measure>>? measuresResponse = await httpClient.GetFromJsonAsync<List<List<Measure>>>(requestUri);
            if (measuresResponse != null)
            {
                foreach(List<Measure> measureList in measuresResponse)
                {
                    ProjectHealthScore phs = new ProjectHealthScore(){
                        Vulnerability = (int)float.Parse(measureList.Find(m => m.metric == "security_rating")?.value ?? "0.0"),
                        Bugs = (int)float.Parse(measureList.Find(m => m.metric == "reliability_rating")?.value ?? "0.0"),
                        CodeSmells = (int)float.Parse(measureList.Find(m => m.metric == "sqale_rating")?.value ?? "0.0"),
                        SecHotspots = (int)float.Parse(measureList.Find(m => m.metric == "security_review_rating")?.value ?? "0.0"),
                    };
                    allProjectHealthScores.Add(phs);
                }
                CalculateOverallHealthScore(allProjectHealthScores);
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            throw;
        }
    }

    protected void CalculateOverallHealthScore(List<ProjectHealthScore> allProjectHealthScores)
    {
        List<double> listOfAvgPHS = new List<double>();
        List<double> weights = (from project in projects select project.Weight).ToList();
        // for each project, sum up the health scores
        for(int i = 0; i < allProjectHealthScores.Count; i++)
        {
            ProjectHealthScore phs = allProjectHealthScores[i];
            double avgPHS = Math.Ceiling((double)
                (
                    phs.Vulnerability + 
                    phs.Bugs + 
                    phs.CodeSmells + 
                    phs.SecHotspots
                ) / 4);
            listOfAvgPHS.Add(avgPHS);
        }
        double sum = listOfAvgPHS.Zip(weights, (w, PHS) => w * PHS).Sum();
        double ohs = Math.Ceiling((1.0/(double)allProjectHealthScores.Count) * sum); // overall health score
        TranslateHealthScore(ohs);
    }

    protected void TranslateHealthScore(double score)
    {
        string grade = "";
        switch(score)
        {
            case 5.0f:
                grade = "E";
                break;
            case 4.0f:
                grade = "D";
                break;
            case 3.0f:
                grade = "C";
                break;
            case 2.0f:
                grade = "B";
                break;
            case 1.0f:
                grade = "A";
                break;
            default:
                grade = "N/A";
                break;
        }
        overallHealthScore = grade;
    }

    // Placeholder for future weight creation logic
    protected List<double> CreateWeights(int numOfProjects)
    {
        // Generate the given number of weights randomly so that they sum to 1
        Random random = new Random();
        List<double> weights = new List<double>();
        int totalWeight = 0;

        for (int i = 0; i < numOfProjects; i++)
        {
            int weight = random.Next(1, 100);
            weights.Add(weight);
            totalWeight += weight;
        }

        weights = weights.Select(w => w / totalWeight).ToList();
        return weights;
    }

    protected string FormatDate(string input)
    {
        var dto = DateTimeOffset.ParseExact(
            input,
            "yyyy-MM-dd'T'HH:mm:ssK",
            System.Globalization.CultureInfo.InvariantCulture
        );
        TimeZoneInfo sgZone = TimeZoneInfo.FindSystemTimeZoneById("Singapore Standard Time");
        DateTime sgTime = TimeZoneInfo.ConvertTime(dto.UtcDateTime, sgZone);
        string formatted = sgTime.ToString("dd MMM yyyy HH:mm:ss");
        return formatted;
    }

    protected async Task RefreshProjects()
    {
        try 
        {
            var requestUri = "api/dashboard/refresh-projects";
            HttpClient httpClient = HttpFactory.CreateClient("LocalApi");
            Debug.WriteLine($"Calling URL: {httpClient.BaseAddress}{requestUri}");
            HttpResponseMessage response = await httpClient.GetAsync(requestUri);
            if (response != null)
            {
                response.EnsureSuccessStatusCode();
                navigationManager.NavigateTo("/", forceLoad: true);
            }
        }
        catch (Exception e)
        {
            Debug.WriteLine("Error refreshing projects data " + e);
            navigationManager.NavigateTo("/Error");
        }
    }

    protected void ToggleProjectsTable()
    {
        showProjectsTable = !showProjectsTable;
    }

    public struct ProjectHealthScore
    {
        public int Vulnerability;
        public int Bugs;
        public int CodeSmells;
        public int SecHotspots;
    }
}