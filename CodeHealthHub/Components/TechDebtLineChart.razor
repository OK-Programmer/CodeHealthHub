@using CodeHealthHub.Components.Pages
@using CodeHealthHub.Models
@using Plotly.Blazor.Traces.IsoSurfaceLib.CapsLib
@inject IHttpClientFactory HttpFactory
@rendermode InteractiveServer

<PlotlyChart Config="config" Layout="layout" Data="data" @ref="chart"/>

@code {
    [Parameter]
    public List<SonarQubeProject> projects { get; set; } = new();
    private PlotlyChart? chart;
    private IList<ITrace>? data { get; set; } = new List<ITrace>();
    private Plotly.Blazor.Layout layout = new();
    private Config config = new();
    private bool _needsUpdate = false;
    private int _lastProjectHash = 0;

    protected class DataPoint() 
    {
        public DateTime dateTime;
        public double value;
    }

    protected override void OnInitialized()
    {
        layout = new Plotly.Blazor.Layout
        {
            Title = new Title { Text = "Project UTD Trend" },
            XAxis = new List<XAxis>
            {
                new XAxis
                {
                    Type = Plotly.Blazor.LayoutLib.XAxisLib.TypeEnum.Date,
                    Title = new Plotly.Blazor.LayoutLib.XAxisLib.Title { Text = "Time" }
                }
            },
            YAxis = new List<YAxis>
            {
                new YAxis
                {
                    Title = new Plotly.Blazor.LayoutLib.YAxisLib.Title { Text = "Unified Tech Debt (hrs)" }
                }
            }
        };

        config = new Config
        {
            Responsive = true
        };
    }
    
    protected override async Task OnParametersSetAsync()
    {
        if (projects == null || projects.Count == 0)
            return;

        int currentHash = projects.GetHashCode();
        if (currentHash == _lastProjectHash)
            return;

        _lastProjectHash = currentHash;

        Debug.WriteLine($"Rebuilding chart at {DateTime.UtcNow:o}");

        var newData = new List<ITrace>();

        foreach (SonarQubeProject proj in projects)
        {
            List<DateTime> xvalues = new();
            List<double> yvalues = new();
            List<ProjectScan>? measuresHist = await GetMeasuresHistory(proj.Id);
            if (measuresHist != null)
            {
                xvalues = measuresHist.Select(h => h.AnalysisDate).ToList();
                yvalues = measuresHist.Select(h => Utility.CalculateUTD(h)).ToList();
            }
            
            List<DataPoint> dataPoints = new();
            for (int i = 0; i < xvalues.Count; i++)
            {
                dataPoints.Add(new DataPoint
                {
                    dateTime = xvalues[i],
                    value = yvalues[i]
                });
            }

            @* ((Scatter)data![0]).X = dataPoints.Select(p => (object)p.dateTime).ToList();
            ((Scatter)data![0]).Y = dataPoints.Select(p => (object)p.value).ToList(); *@

            newData.Add(new Scatter
            {
                Name = proj.Name,
                Mode = Plotly.Blazor.Traces.ScatterLib.ModeFlag.Lines | Plotly.Blazor.Traces.ScatterLib.ModeFlag.Markers,
                X = dataPoints.Select(p => (object)p.dateTime).ToList(),
                Y = dataPoints.Select(p => (object)p.value).ToList()
            });
        }

        data = newData;
        _needsUpdate = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_needsUpdate)
            return;

        _needsUpdate = false;

        if (chart is not null)
            await chart.React();
    }

    protected async Task<List<ProjectScan>?> GetMeasuresHistory(int Id) 
    {
        List<ProjectScan> projScanList = new();

        string? requestUri = $"api/dashboard/measures-history/{Id}";
        HttpClient httpClient = HttpFactory.CreateClient("LocalApi");
        Debug.WriteLine($"Calling URL: {httpClient.BaseAddress}{requestUri}");
        try
        {
            var response = await httpClient.GetAsync(requestUri);
            if (response.IsSuccessStatusCode)
            {
                List<ProjectScan>? measuresResponse = await response.Content.ReadFromJsonAsync<List<ProjectScan>>();
                if (measuresResponse != null)
                {
                    projScanList.AddRange(measuresResponse);
                }
            }
            else
            {
                Debug.WriteLine($"Error fetching measures: {response.ReasonPhrase}");
            }
            return projScanList;
        }
        catch (Exception)
        {
            return null;
            throw;
        }
    }
}