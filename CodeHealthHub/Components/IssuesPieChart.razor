@using CodeHealthHub.Models

<div class="chart-container">
    <PieChart @ref="pieChart"></PieChart>
</div>

@code {
    [Parameter]
    public List<Issue>? Issues { get; set; }
    
    private PieChart pieChart = default!;
    private PieChartOptions pieChartOptions = default!;
    private BlazorExpress.ChartJS.ChartData chartData = default!;

    private List<Issue>? previousIssues = null;
    private bool chartInitialized = false;

    protected override void OnInitialized()
    {
        pieChartOptions = new();
        pieChartOptions.Responsive = true;
        pieChartOptions.MaintainAspectRatio = true;
        pieChartOptions.Plugins.Title!.Text = "Issues Severity Distribution";
        pieChartOptions.Plugins.Title.Display = true;
    }

    protected override void OnParametersSet()
    {
        // Only rebuild if Issues data actually changed
        if (!ReferenceEquals(Issues, previousIssues))
        {
            previousIssues = Issues;
            
            if (Issues != null && Issues.Any())
            {
                chartData = new BlazorExpress.ChartJS.ChartData { Labels = GetDataLabels(), Datasets = GetDataSets(1) };
            }
            else
            {
                chartData = new BlazorExpress.ChartJS.ChartData { Labels = new List<string>(), Datasets = new List<IChartDataset>() };
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await pieChart.InitializeAsync(chartData, pieChartOptions, plugins: new[] { "ChartDataLabels" });
            chartInitialized = true;
        }
        else if (chartInitialized && Issues != null && Issues.Any())
        {
            // If chart already initialized but data changed, update it
            await pieChart.UpdateAsync(chartData, pieChartOptions);
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    #region Data Preparation

    private List<IChartDataset> GetDataSets(int numberOfDatasets)
    {
        var datasets = new List<IChartDataset>();

        for (var index = 0; index < numberOfDatasets; index++)
        {
            datasets.Add(GetDataset());
        }

        return datasets;
    }
    
    private PieChartDataset GetDataset()
    {
        var dataset = new PieChartDataset()
        {
            Label = "Number of Issues",
            Data = GetDatasetValues(),
            BackgroundColor = GetDatasetBackgroundColors(),
        };

        dataset.Datalabels.Anchor = DataLabelAnchor.Center;
        dataset.Datalabels.BackgroundColor = "black";
        return dataset;
    }

    private List<double?> GetDatasetValues()
    {
        var data = new List<double?>();

        if (Issues != null)
        {
            var groupedIssues = Issues.GroupBy(i => i.Severity).ToList();

            groupedIssues.ForEach(g =>
            {
                data.Add(g.Count());
            });
        }

        return data;
    }

    private List<string> GetDatasetBackgroundColors()
    {
        var colors = new List<string>();

        if (Issues != null)
        {
            var groupedIssues = Issues.GroupBy(i => i.Severity).ToList();
            groupedIssues.ForEach((g) =>
            {
                switch(g.Key)
                {
                    case "BLOCKER":
                        colors.Add("rgb(0, 0, 0)"); // Black
                        break;
                    case "CRITICAL":
                        colors.Add("rgb(255, 80, 80)"); // Red
                        break;
                    case "MAJOR":
                        colors.Add("rgb(250, 150, 80)"); // Orange
                        break;
                    case "MINOR":
                        colors.Add("rgb(250, 250, 80)"); // Yellow
                        break;
                    case "INFO":
                        colors.Add("rgb(100, 255, 60)"); // Green
                        break;
                    default: 
                        colors.Add("rgb(201, 203, 207)"); // Grey
                        break;
                }
            });
        }

        return colors;
    }

    private List<string> GetDataLabels()
    {
        var labels = new List<string>();
        
        if (Issues != null)
        {
            Issues.GroupBy(i => i.Severity).ToList().ForEach(g =>
            {
                labels.Add(g.Key);
            });
        }

        return labels;
    }

    #endregion  Data Preparation
}
