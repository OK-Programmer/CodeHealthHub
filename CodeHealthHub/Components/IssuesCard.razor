@using CodeHealthHub.Models

<div class="card-body">
    <h5 class="card-title">
        Issues
        <CardTooltip TooltipText="@tooltipText"/>
    </h5>
    <p class="card-text">
        Total Count: @issuesCount <br />
        Total Effort: @effortTotal mins
    </p>
</div>

@code {
    [Parameter]
    public int? issuesCount { get; set; }
    [Parameter]
    public int? effortTotal { get; set; }
    private string tooltipText = "This card displays the total number of issues detected across all projects and the cumulative effort required to resolve them, measured in minutes.";
}
