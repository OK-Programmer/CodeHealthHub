@using CodeHealthHub.Components.Pages
@using CodeHealthHub.Models
@using Microsoft.AspNetCore.Components.QuickGrid

<div class="card-body">
    <CardTooltip TooltipText="@tooltipText"/>
    <h5 class="card-title">
        Security Vulnerable
    </h5>
    @if (topVulnProjects != null && topVulnProjects.Count() != 0)
    {
        int index = 0;
        <ol class="card-text list-group list-group-numbered">
            @while (index < topVulnProjects.Count() && index < 3)
            {
                var proj = topVulnProjects[index];
                var num = index + 1;
                <li class="list-group-item p-1">@proj.ProjName (@proj.Severity: @proj.VulnCount)</li>
                index++;
            }
        </ol>
    }
    else
    {
        <p class="fs-5">No vulnerable projects.</p>
    }
</div>

@code {
    [Parameter]
    public List<SonarQubeProject>? projects { get; set; }
    [Parameter]
    public List<ProjectIssue>? issues { get; set; }
    private List<ListItem> topVulnProjects = new();
    private string tooltipText = "This card highlights the top three projects with the highest number of security vulnerabilities, categorized by severity levels such as Blocker, Critical, Major, and Minor.";

    class ListItem
    {
        public string ProjName { get; set; } = string.Empty;
        public string Severity { get; set; } = string.Empty;
        public int VulnCount { get; set; } = 0;
    }

    protected override void OnParametersSet()
    {
        if (issues!.Count() == 0 || projects!.Count() == 0) return;

        GetMostVulnProjs();
    }

    private void GetMostVulnProjs()
    {
        // Find any proj with blockers
        var projWithBlockers = GetProjWithSeverity("BLOCKER");
        if (projWithBlockers != null)
        {
            topVulnProjects.Add(projWithBlockers);
        }

        // Find any proj with criticals
        var projWithCriticals = GetProjWithSeverity("CRITICAL");
        if (projWithCriticals != null)
        {
            topVulnProjects.Add(projWithCriticals);
        }

        // Find any proj with majors
        var projWithMajors = GetProjWithSeverity("MAJOR");
        if (projWithMajors != null)
        {
            topVulnProjects.Add(projWithMajors);
        }

        // Find any proj with minors
        var projWithMinors = GetProjWithSeverity("MINOR");
        if (projWithMinors != null)
        {
            topVulnProjects.Add(projWithMinors);
        }
    }

    private ListItem? GetProjWithSeverity(string severity)
    {
        int? projId = issues!
            .Where(i => i.Type == "VULNERABILITY" && i.Severity == severity)
            .GroupBy(i => i.SonarQubeProjectId)
            .OrderByDescending(g => g.Count())
            .Select(g => g.Key)
            .FirstOrDefault(-1);

        if (projId != -1)
        {
            var proj = projects!.Find(p => p.Id == projId);

            // check if topVulnProjects already contains project
            var alreadyContains = topVulnProjects.Any(p => p.ProjName == proj!.Name);
            if (alreadyContains)
            {
                return null;
            }

            var vulnCount = issues!
                .Where(i => 
                    i.SonarQubeProjectId == projId && 
                    i.Severity == severity && 
                    i.Type == "VULNERABILITY")
                .Count();

            return new ListItem()
            {
                ProjName = projects!.Find(p => p.Id == projId)!.Name,
                Severity = severity.ToLower(),
                VulnCount = vulnCount
            };
        }

        return null;
    }
}
