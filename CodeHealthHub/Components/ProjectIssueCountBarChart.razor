@using CodeHealthHub.Models

@* <div class="chart-container">
</div>  *@
<BarChart Height=300 @ref="barChart"></BarChart>

@code {
    @* [Parameter]
    public List<SonarQubeProject>? Projects { get; set; } *@
    [Parameter]
    public List<ProjectIssue>? Issues { get; set; }
    [Parameter]
    public List<SonarQubeProject>? projects { get; set; }
    private List<ProjectIssue>? previousIssues = null;
    private BarChart barChart = default!;
    private BarChartOptions barChartOptions = default!;
    private BlazorExpress.ChartJS.ChartData chartData = default!;
    private bool chartInitialized = false;

    protected override void OnInitialized()
    {
        barChartOptions = new BarChartOptions();
        barChartOptions.Responsive = true;
        barChartOptions.MaintainAspectRatio = false;
        barChartOptions.Interaction = new Interaction { Mode = BlazorExpress.ChartJS.InteractionMode.X };
        barChartOptions.IndexAxis = "x";

        barChartOptions.Plugins.Title!.Text = "Number of Issues Per Project";
        barChartOptions.Plugins.Title.Display = true;
        barChartOptions.Scales.X!.Title = new ChartAxesTitle { Text = "Project", Display = true };
        barChartOptions.Scales.Y!.Title = new ChartAxesTitle { Text = "Number of Issues", Display = true };

        barChartOptions.Plugins.Legend.Display = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Only rebuild if Issues data actually changed
        if (!ReferenceEquals(Issues, previousIssues))
        {
            previousIssues = Issues;
            
            if (Issues != null && Issues.Any())
            {
                var labels = GetLabels() ?? new List<string>();
                @* var labels = Issues.Select(i => i.project).Distinct().ToList(); *@
                var datasets = new List<IChartDataset>();

                var dataset1 = new BarChartDataset()
                {
                    Data = GetDataPoints(),
                    BackgroundColor = GetColors()
                    @* BorderColor = new List<string> { ColorUtility.CategoricalTwelveColors[labels.Count] }, *@
                    @* BorderWidth = new List<double> { 0 }, *@
                };
                datasets.Add(dataset1);

                chartData = new BlazorExpress.ChartJS.ChartData { Labels = labels, Datasets = datasets };
            }
            else
            {
                chartData = new BlazorExpress.ChartJS.ChartData { Labels = new List<string>(), Datasets = new List<IChartDataset>() };
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await barChart.InitializeAsync(chartData, barChartOptions);
            chartInitialized = true;
        }
        else if (chartInitialized && Issues != null && Issues.Any())
        {
            // If chart already initialized but data changed, update it
            await barChart.UpdateAsync(chartData, barChartOptions);
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    protected List<double?> GetDataPoints()
    {
        List<double?> dataPoints = new();
        if (Issues != null && Issues.Any())
        {
            var labels = GetLabels()?? new List<string>();
            foreach(var label in labels)
            {
                var count = Issues.Count(i => 
                    {
                        var project = projects?.FirstOrDefault(p => p.Name == label);
                        return project != null && i.Project == project.Key;
                    });
                dataPoints.Add(count);
            }
            @* var labels = Issues.Select(i => i.project).Distinct().ToList();
            foreach(var label in labels)
            {
                var count = Issues.Count(i => i.project == label);
                dataPoints.Add(count);
            } *@
            return dataPoints;
        }
        else 
        { 
            return new List<double?>();
        }
    }

    protected List<string>? GetLabels()
    {
        if (Issues != null && Issues.Any())
        {
            var projectKeys = (from issue in Issues select issue.Project).Distinct().ToList();
            var projectNames = projects?.Where(p => projectKeys.Contains(p.Key)).Select(p => p.Name).ToList();
            return projectNames;
        }
        else 
        { 
            return new List<string>(); 
        }
    }

    protected List<string> GetColors()
    {
        List<string> colors = new();

        for (int i = 0; i < projects!.Count; i++)
        {
            colors.Add(ColorUtility.CategoricalTwelveColors[i]);
        }

        return colors;
    }
}